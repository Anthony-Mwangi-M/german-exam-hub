# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── M-Pesa Payment (Daraja API) ─────────────────────────────────────────────
# Set as Supabase SECRETS (not frontend env vars):
#   npx supabase secrets set MPESA_CONSUMER_KEY=... MPESA_CONSUMER_SECRET=...
#   npx supabase secrets set MPESA_SHORTCODE=174379 MPESA_PASSKEY=...
#   npx supabase secrets set MPESA_ENVIRONMENT=sandbox
#   npx supabase secrets set MPESA_CALLBACK_URL=https://<project>.supabase.co/functions/v1/mpesa-callback
#
# Deploy launch functions only (AI evaluate-* functions are deferred):
#   npx supabase functions deploy mpesa-stk-push mpesa-callback mpesa-query demo-complete-purchase

# ─── Payment mode (pick one for testing / production) ───────────────────────
# Demo (no M-Pesa): testing before Daraja is ready
VITE_USE_DEMO_PAYMENTS=true
VITE_USE_REAL_MPESA=false

# Production: set VITE_USE_REAL_MPESA=true, VITE_USE_DEMO_PAYMENTS=false
# Also set Supabase secret for edge-function demo (optional): ENABLE_DEMO_PAYMENTS=true
# Demo checkout uses DB RPC complete_demo_purchase — run migration 031

# ─── NOTE: No AI keys needed ─────────────────────────────────────────────────
# Writing and speaking assessments are marked manually by instructors.
